func main() {
    let score = 90

    if score >= 90 {
        4
    } elif score >= 80 {
        3
    } elif score >= 70 {
        2
    } elif score >= 60 {
        1
    } else {
        0
    }

    // can also
    let gpa = if score >= 90 { 4 } elif score >= 80 { 3 } elif score >= 70 { 2 } elif score >= 60 { 1 } else { 0 }
}