func report(math: Int, science: Int) -> Bool {
    struct Grade {
        score: Int
        passing: Int
    }

    func passed(g: Grade) -> Bool {
        g.score >= g.passing
    }

    let math_grade = Grade(math, 60)
    let science_grade = Grade(science, 50)

    passed(math_grade) && passed(science_grade)
}

func main() {
    let graduated = report(75, 80)
}
